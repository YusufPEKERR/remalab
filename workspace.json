{
  "workspaceName": "Phone Parts Warehouse Management System",
  "version": "1.0.0",
  "environment": {
    "databaseType": "PostgreSQL",
    "defaultSchema": "public",
    "autoSync": true
  },
  "modules": [
    {
      "name": "Warehouse Module",
      "path": "/modules/warehouse",
      "entryPoint": "stock_entry_form"
    }
  ],
  "roles": [
    "admin",
    "warehouse_worker"
  ],
  "git": {
    "syncBranch": "main",
    "shareEnvironmentSettings": true
  }
}
